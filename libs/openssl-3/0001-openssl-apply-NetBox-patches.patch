From 70f0e3da59497b445fd384e07ecae5d6bd0beaac Mon Sep 17 00:00:00 2001
From: Mikhail Lukashov <michael.lukashov@gmail.com>
Date: Sun, 19 Oct 2025 13:19:43 +0300
Subject: [PATCH] openssl: apply NetBox patches

---
 libs/openssl-3/crypto/core_namemap.c           |  2 +-
 libs/openssl-3/crypto/cryptlib.c               |  2 +-
 libs/openssl-3/crypto/objects/obj_dat.c        |  4 ++--
 libs/openssl-3/crypto/property/property.c      |  2 +-
 libs/openssl-3/include/crypto/bn_conf.h        | 11 +++++++++++
 libs/openssl-3/include/internal/rcu.h          |  2 ++
 libs/openssl-3/include/openssl/configuration.h | 11 +++++++++++
 libs/openssl-3/ssl/ssl_lib.c                   |  2 +-
 libs/openssl-3/ssl/statem/extensions.c         |  2 +-
 9 files changed, 31 insertions(+), 7 deletions(-)

diff --git a/libs/openssl-3/crypto/core_namemap.c b/libs/openssl-3/crypto/core_namemap.c
index cf88e1873..b7e4ac08b 100644
--- a/libs/openssl-3/crypto/core_namemap.c
+++ b/libs/openssl-3/crypto/core_namemap.c
@@ -103,7 +103,7 @@ int ossl_namemap_empty(OSSL_NAMEMAP *namemap)
     return rv;
 #else
     /* Have TSAN support */
-    return namemap == NULL || tsan_load(&namemap->max_number) == 0;
+    return namemap == NULL || tsan_load((volatile LONG *)&namemap->max_number) == 0;
 #endif
 }
 
diff --git a/libs/openssl-3/crypto/cryptlib.c b/libs/openssl-3/crypto/cryptlib.c
index ef55cc022..d86898a33 100644
--- a/libs/openssl-3/crypto/cryptlib.c
+++ b/libs/openssl-3/crypto/cryptlib.c
@@ -42,7 +42,7 @@ int OPENSSL_isservice(void)
     WCHAR *name;
     static union {
         void *p;
-        int (*f) (void);
+        FARPROC f; // int (*f) (void);
     } _OPENSSL_isservice = {
         NULL
     };
diff --git a/libs/openssl-3/crypto/objects/obj_dat.c b/libs/openssl-3/crypto/objects/obj_dat.c
index 482718ead..0979a690a 100644
--- a/libs/openssl-3/crypto/objects/obj_dat.c
+++ b/libs/openssl-3/crypto/objects/obj_dat.c
@@ -226,7 +226,7 @@ void ossl_obj_cleanup_int(void)
  */
 static int obj_new_nid_unlocked(int num)
 {
-    static TSAN_QUALIFIER int new_nid = NUM_NID;
+    static TSAN_QUALIFIER LONG new_nid = NUM_NID;
 #ifdef TSAN_REQUIRES_LOCKING
     int i;
 
@@ -235,7 +235,7 @@ static int obj_new_nid_unlocked(int num)
 
     return i;
 #else
-    return tsan_add(&new_nid, num);
+    return tsan_add((volatile LONG *)&new_nid, num);
 #endif
 }
 
diff --git a/libs/openssl-3/crypto/property/property.c b/libs/openssl-3/crypto/property/property.c
index 03e83facf..81ab6b07e 100644
--- a/libs/openssl-3/crypto/property/property.c
+++ b/libs/openssl-3/crypto/property/property.c
@@ -695,7 +695,7 @@ static void ossl_method_cache_flush_some(OSSL_METHOD_STORE *store)
     store->cache_nelem = state.nelem;
     /* Without a timer, update the global seed */
     if (state.using_global_seed)
-        tsan_add(&global_seed, state.seed);
+        tsan_add((volatile LONG *)&global_seed, (LONG64)state.seed);
 }
 
 int ossl_method_store_cache_get(OSSL_METHOD_STORE *store, OSSL_PROVIDER *prov,
diff --git a/libs/openssl-3/include/crypto/bn_conf.h b/libs/openssl-3/include/crypto/bn_conf.h
index 824347f2c..16d4d4516 100644
--- a/libs/openssl-3/include/crypto/bn_conf.h
+++ b/libs/openssl-3/include/crypto/bn_conf.h
@@ -25,6 +25,14 @@
 
 /* Only one for the following should be defined */
 /* clang-format off */
+#if defined(_WIN64) || defined(OPENSSL_SYS_WIN64) || defined(_M_ARM64)
+#undef SIXTY_FOUR_BIT_LONG
+#define SIXTY_FOUR_BIT
+#undef THIRTY_TWO_BIT
+
+#else
+
+#if defined(_WIN32) || defined(OPENSSL_SYS_WIN32)
 #undef SIXTY_FOUR_BIT_LONG
     /* clang-format on */
     /* clang-format off */
@@ -33,5 +41,8 @@
     /* clang-format off */
 #define THIRTY_TWO_BIT
 /* clang-format on */
+#endif
+
+#endif
 
 #endif
diff --git a/libs/openssl-3/include/internal/rcu.h b/libs/openssl-3/include/internal/rcu.h
index a89794c0c..54bd64beb 100644
--- a/libs/openssl-3/include/internal/rcu.h
+++ b/libs/openssl-3/include/internal/rcu.h
@@ -27,7 +27,9 @@ void ossl_synchronize_rcu(CRYPTO_RCU_LOCK *lock);
 int ossl_rcu_call(CRYPTO_RCU_LOCK *lock, rcu_cb_fn cb, void *data);
 void *ossl_rcu_uptr_deref(void **p);
 void ossl_rcu_assign_uptr(void **p, void **v);
+#ifndef WINSCP
 #define ossl_rcu_deref(p) ossl_rcu_uptr_deref((void **)p)
 #define ossl_rcu_assign_ptr(p, v) ossl_rcu_assign_uptr((void **)p, (void **)v)
+#endif
 
 #endif
diff --git a/libs/openssl-3/include/openssl/configuration.h b/libs/openssl-3/include/openssl/configuration.h
index ebe4226d9..850040c90 100644
--- a/libs/openssl-3/include/openssl/configuration.h
+++ b/libs/openssl-3/include/openssl/configuration.h
@@ -27,9 +27,20 @@ extern "C" {
  * OpenSSL was configured with the following options:
  */
 
+#if defined(_WIN64)
+
+# ifndef OPENSSL_SYS_WIN64A
+#  define OPENSSL_SYS_WIN64A 1
+# endif
+
+#elif defined(_WIN32)
+
 # ifndef OPENSSL_SYS_WIN32
 #  define OPENSSL_SYS_WIN32 1
 # endif
+
+#endif
+
 # define OPENSSL_CONFIGURED_API 30100
 # ifndef OPENSSL_RAND_SEED_OS
 #  define OPENSSL_RAND_SEED_OS
diff --git a/libs/openssl-3/ssl/ssl_lib.c b/libs/openssl-3/ssl/ssl_lib.c
index e89577483..2ee4a7e6c 100644
--- a/libs/openssl-3/ssl/ssl_lib.c
+++ b/libs/openssl-3/ssl/ssl_lib.c
@@ -3012,7 +3012,7 @@ static int ssl_tsan_load(SSL_CTX *ctx, TSAN_QUALIFIER int *stat)
     int res = 0;
 
     if (ssl_tsan_lock(ctx)) {
-        res = tsan_load(stat);
+        res = tsan_load((volatile LONG64 *)stat);
         ssl_tsan_unlock(ctx);
     }
     return res;
diff --git a/libs/openssl-3/ssl/statem/extensions.c b/libs/openssl-3/ssl/statem/extensions.c
index 6b180e254..674686929 100644
--- a/libs/openssl-3/ssl/statem/extensions.c
+++ b/libs/openssl-3/ssl/statem/extensions.c
@@ -977,7 +977,7 @@ static int final_server_name(SSL_CONNECTION *s, unsigned int context, int sent)
     if (SSL_IS_FIRST_HANDSHAKE(s) && sctx != s->session_ctx
         && s->hello_retry_request == SSL_HRR_NONE) {
         ssl_tsan_counter(sctx, &sctx->stats.sess_accept);
-        ssl_tsan_decr(s->session_ctx, &s->session_ctx->stats.sess_accept);
+        ssl_tsan_decr(s->session_ctx, (volatile LONG *)&s->session_ctx->stats.sess_accept);
     }
 
     /*
-- 
