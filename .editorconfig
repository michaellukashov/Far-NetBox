# EditorConfig for NetBox Project
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,h,hpp,c}]
indent_style = space
indent_size = 2
max_line_length = 120

[*.{md,markdown}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{cmake,CMakeLists.txt}]
indent_style = space
indent_size = 2

[*.{bat,cmd}]
indent_style = space
indent_size = 2
end_of_line = crlf

[*.{rc,lng}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
